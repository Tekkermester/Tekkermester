// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left",
    "tree_view": true
  },
  "vim": {
    "toggle_relative_line_numbers": true
  },
  "colorize_brackets": true,
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle"
  },
  "preview_tabs": {
    "enable_preview_from_file_finder": false
  },
  "tabs": {
    "close_position": "right",
    "file_icons": false,
    "git_status": false
  },

  "title_bar": {
    "show_branch_status_icon": true
  },
  "project_panel": {
    "dock": "left",
    "button": true
  },
  "prettier": {
    "allowed": true
  },
  "languages": {
    "C": {
      "show_edit_predictions": false
    },
    "Python": {
      "show_edit_predictions": false
    }
  },
  "show_edit_predictions": false,
  "git": {
    "inline_blame": {
      "enabled": false
    },
    "blame": {
      "show_avatar": true
    }
  },
  "scrollbar": {
    "git_diff": true
  },
  "agent": {
    "dock": "right",
    "tool_permissions": {
      "default": "allow"
    },
    "default_profile": "write",
    "default_model": {
      "enable_thinking": false,
      "effort": "high",
      "provider": "copilot_chat",
      "model": "gpt-5-mini"
    },
    "model_parameters": []
  },
  "disable_ai": false,
  "terminal": {
    "font_weight": 397.0,
    "font_family": "MesloLGS NF"
  },
  "format_on_save": "off",
  "auto_update": true,
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Material Icon Theme"
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": false
  },
  "vim_mode": true,
  "base_keymap": "JetBrains",
  "ui_font_size": 16,
  "buffer_font_size": 14,
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Ayu Dark"
  },
  "buffer_font_features": {
    // Disable ligatures:
    "calt": false
  },
  // self, bool, None...
  "experimental.theme_overrides": {
      "syntax": {
        "variable.special": { "color": "#D55FDE" },
        "boolean": {"color": "#FF7136"},
        "constant":{"color": "#FF7E31"},

        "string.special.symbol": { "color": "#FF0000" },

      }
    }

}
